          <path d="M20,50 L60,50 L66,50 L70,35 L74,65 L78,45 L82,50 L160,50
                   L166,50 L170,35 L174,65 L178,45 L182,50 L260,50
                   L266,50 L270,35 L274,65 L278,45 L282,50 L360,50" fill="none" stroke="#00ff88" stroke-width="1.5"/>

          <text x="400" y="30" fill="#6a8099" font-size="9">50 Hz Mains Interference</text>
          <path d="M400,50 q3,-8 6,0 q3,-8 6,0 q3,-8 6,0 q3,-8 6,0 q3,-8 6,0 q3,-8 6,0
                    q3,-8 6,0 q3,-8 6,0 q3,-8 6,0 q3,-8 6,0 q3,-8 6,0 q3,-8 6,0
                    q3,-8 6,0 q3,-8 6,0 q3,-8 6,0 q3,-8 6,0 q3,-8 6,0 q3,-8 6,0"
                fill="none" stroke="#ff4466" stroke-width="1.2"/>
          <text x="400" y="72" fill="#ff4466" font-size="8">→ check earth continuity, screen cable routing</text>

          <text x="20" y="120" fill="#6a8099" font-size="9">Motion Artifact (baseline wander)</text>
          <path d="M20,150 Q60,130 100,160 Q140,180 180,145 Q220,120 260,155 Q300,175 340,140"
                fill="none" stroke="#ffb347" stroke-width="1.5"/>
          <text x="20" y="192" fill="#ffb347" font-size="8">→ patient movement, poor electrode adhesion</text>

          <text x="400" y="120" fill="#6a8099" font-size="9">SpO₂ Low Perfusion Noise</text>
          <path d="M400,155 l3,-2 l3,4 l3,-6 l3,8 l3,-4 l3,2 l3,-3 l3,5 l3,-7 l3,9 l3,-5
                   l3,3 l3,-4 l3,6 l3,-8 l3,10 l3,-6 l3,4 l3,-5" fill="none" stroke="#aa88ff" stroke-width="1.2"/>
          <text x="400" y="192" fill="#aa88ff" font-size="8">→ cold extremity, poor probe siting, nail polish</text>
        </svg>
      </div>
      <div class="component-list">
        <div class="component-item">
          <div class="comp-name">Mains Interference (50/60 Hz) <span class="tag tag-med">ENVIRONMENTAL</span></div>
          <div class="comp-desc">Enters via poorly screened lead wires or broken earth reference. Check notch filter engagement, cable screening continuity, and nearby equipment earthing.</div>
        </div>
        <div class="component-item">
          <div class="comp-name">Electromyographic (EMG) Noise <span class="tag tag-low">PHYSIOLOGICAL</span></div>
          <div class="comp-desc">Muscle tremor or shivering contaminates the ECG high-frequency band. Not a device fault — verify filter settings match clinical context (monitor vs. diagnostic mode).</div>
        </div>
        <div class="component-item">
          <div class="comp-name">Motion / Baseline Wander <span class="tag tag-med">MECHANICAL</span></div>
          <div class="comp-desc">Low-frequency drift from electrode movement or respiration. Verify electrode adhesive condition and skin prep; check high-pass filter corner frequency.</div>
        </div>
        <div class="component-item">
          <div class="comp-name">SpO₂ Motion / Perfusion Artifact <span class="tag tag-low">PHYSIOLOGICAL</span></div>
          <div class="comp-desc">Modern algorithms use adaptive filtering (e.g. Masimo SET, Nellcor OxiMax) to reject motion — confirm algorithm version is current and licensed if module supports it.</div>
        </div>
      </div>
    </div>

    <!-- PPM -->
    <div id="sec-ppm" class="section">
      <div class="canvas-title">Planned Preventive Maintenance</div>
      <div class="canvas-subtitle">Typical Annual PPM Schedule</div>
      <div class="diagram-wrap" style="padding:12px">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--text2);letter-spacing:2px;margin-bottom:10px;text-transform:uppercase">Ref: Manufacturer Service Manual + MHRA Device Bulletin</div>
        <div class="ppm-row" style="border-bottom:1px solid var(--border)">
          <div style="font-size:9px;color:var(--text2);letter-spacing:1px;text-transform:uppercase">TASK</div>
          <div style="font-size:9px;color:var(--text2);letter-spacing:1px;text-transform:uppercase">FREQUENCY</div>
          <div style="font-size:9px;color:var(--text2);letter-spacing:1px;text-transform:uppercase">STATUS</div>
        </div>
        <div class="ppm-row"><div class="ppm-task">Visual inspection — casing, cables, connectors, display</div><div class="ppm-freq">Annual</div><span class="tag tag-ok">PASS</span></div>
        <div class="ppm-row"><div class="ppm-task">Electrical safety test — earth continuity, leakage current</div><div class="ppm-freq">Annual</div><span class="tag tag-ok">PASS</span></div>
        <div class="ppm-row"><div class="ppm-task">ECG simulator test — rate accuracy, arrhythmia detection (EC13 waveforms)</div><div class="ppm-freq">Annual</div><span class="tag tag-high">CRITICAL</span></div>
        <div class="ppm-row"><div class="ppm-task">SpO₂ functional tester verification</div><div class="ppm-freq">Annual</div><span class="tag tag-med">CHECK</span></div>
        <div class="ppm-row"><div class="ppm-task">NIBP calibration — reference manometer, leak test, over-pressure cutoff</div><div class="ppm-freq">Annual</div><span class="tag tag-high">CRITICAL</span></div>
        <div class="ppm-row"><div class="ppm-task">IBP zero/gain calibration — pressure simulator</div><div class="ppm-freq">Annual</div><span class="tag tag-high">CRITICAL</span></div>
        <div class="ppm-row"><div class="ppm-task">Temperature channel verification — decade box / calibrated probe</div><div class="ppm-freq">Annual</div><span class="tag tag-med">CHECK</span></div>
        <div class="ppm-row"><div class="ppm-task">Alarm audio level and priority distinction (IEC 60601-1-8)</div><div class="ppm-freq">Annual</div><span class="tag tag-med">CHECK</span></div>
        <div class="ppm-row"><div class="ppm-task">Nurse-call relay function test</div><div class="ppm-freq">Annual</div><span class="tag tag-med">CHECK</span></div>
        <div class="ppm-row"><div class="ppm-task">Battery capacity test — load test to 80% DoD</div><div class="ppm-freq">Annual</div><span class="tag tag-med">CHECK</span></div>
        <div class="ppm-row"><div class="ppm-task">Firmware version verification + update if applicable</div><div class="ppm-freq">Annual</div><span class="tag tag-ok">VERIFY</span></div>
        <div class="ppm-row"><div class="ppm-task">Network / central station connectivity check</div><div class="ppm-freq">Annual</div><span class="tag tag-ok">VERIFY</span></div>
        <div class="ppm-row"><div class="ppm-task">Clean casing, connectors, and cuff hose fittings</div><div class="ppm-freq">Annual</div><span class="tag tag-ok">CLEAN</span></div>
        <div class="ppm-row"><div class="ppm-task">Replace worn NIBP hose, SpO₂ cable strain relief</div><div class="ppm-freq">As needed</div><span class="tag tag-low">CONDITION</span></div>
      </div>
    </div>

    <!-- FAULTS -->
    <div id="sec-faults" class="section">
      <div class="canvas-title">Fault Diagnosis</div>
      <div class="canvas-subtitle">Systematic Fault Tree</div>
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="fault-block">
          <div class="fault-title">⚠ SYMPTOM: Persistent "Lead Off" / Noisy ECG Trace</div>
          <div class="fault-item">Dried or expired electrode gel — replace electrodes, check expiry date</div>
          <div class="fault-item">Lead wire continuity fault — inspect strain relief points; test wire-to-wire resistance</div>
          <div class="fault-item">Poor skin preparation — clinical practice issue, not device fault; document accordingly</div>
          <div class="fault-item">Patient module connector pins corroded/bent — inspect and clean docking connector</div>
        </div>
        <div class="fault-block" style="border-color:rgba(255,179,71,0.3);background:rgba(255,179,71,0.03)">
          <div class="fault-title" style="color:var(--warn)">⚠ SYMPTOM: SpO₂ Fails to Read or Reads Intermittently</div>
          <div class="fault-item">LED or photodiode degraded — verify with dedicated SpO₂ functional tester, not just visual check</div>
          <div class="fault-item">Probe cable fracture near connector — a very common failure point from repeated flexing</div>
          <div class="fault-item">Ambient light interference — check probe housing seal and clinical shielding</div>
          <div class="fault-item">Incompatible third-party probe — verify probe/monitor compatibility list against manufacturer IFU</div>
        </div>
        <div class="fault-block" style="border-color:rgba(170,136,255,0.3);background:rgba(170,136,255,0.03)">
          <div class="fault-title" style="color:#aa88ff">⚠ SYMPTOM: NIBP Repeated "Unable to Measure" Errors</div>
          <div class="fault-item">Cuff hose leak — pressurise closed system and check for decay against reference gauge</div>
          <div class="fault-item">Pump motor degraded — inflation time exceeds spec; measure inflation rate directly</div>
          <div class="fault-item">Incorrect cuff size for limb — clinical/user issue; verify against cuff sizing chart</div>
          <div class="fault-item">Valve solenoid sticking — deflation rate outside spec; test with calibrated pressure simulator</div>
        </div>
        <div class="fault-block" style="border-color:rgba(0,255,136,0.2);background:rgba(0,255,136,0.02)">
          <div class="fault-title" style="color:var(--accent2)">⚠ SYMPTOM: IBP Trace Damped or Zero Drifting</div>
          <div class="fault-item">Air bubble in pressure line — flush line, verify with disposable transducer replacement</div>
          <div class="fault-item">Transducer zero drift — recalibrate against reference manometer; replace if outside tolerance</div>
          <div class="fault-item">Loose or corroded module connector — inspect docking interface and cable pins</div>
        </div>
      </div>
    </div>

    <!-- ACCURACY -->
    <div id="sec-accuracy" class="section">
      <div class="canvas-title">Accuracy Testing &amp; Verification</div>
      <div class="canvas-subtitle">Simulator-Based Method — Multi-Parameter Compliant</div>
      <div class="card-grid" style="margin-bottom:16px">
        <div class="card">
          <div class="card-label">Method</div>
          <div style="font-size:14px;font-weight:600;color:var(--accent)">Patient Simulator</div>
          <div class="card-desc">Calibrated multi-parameter simulator (e.g. Fluke ProSim, Datrend) injects known ECG, SpO₂, NIBP, IBP, and temperature signals for direct comparison against displayed values.</div>
        </div>
        <div class="card">
          <div class="card-label">ECG Rate Accuracy</div>
          <div class="card-value">±10%<span class="card-unit">or 5 bpm</span></div>
          <div class="card-desc">Whichever is greater, across the clinically relevant HR range, per IEC 60601-2-27.</div>
        </div>
        <div class="card">
          <div class="card-label">Arrhythmia Validation</div>
          <div style="font-size:14px;font-weight:600;color:var(--accent2)">ANSI/AAMI EC13</div>
          <div class="card-desc">Standard test waveform library (VF, VT, asystole, PVCs) run through simulator to verify correct classification and alarm response.</div>
        </div>
        <div class="card">
          <div class="card-label">NIBP Validation</div>
          <div class="card-value">ISO 81060-2<span class="card-unit"></span></div>
          <div class="card-desc">Mean difference ≤5 mmHg, SD ≤8 mmHg vs. auscultatory reference across the validated population range.</div>
        </div>
      </div>
      <div class="diagram-wrap" style="padding:12px">
        <div style="font-size:11px;font-family:'IBM Plex Mono',monospace;color:var(--accent);letter-spacing:1px;margin-bottom:10px;text-transform:uppercase">Acceptance Criteria Decision Tree</div>
        <svg viewBox="0 0 680 160" width="100%" style="max-height:160px">
          <defs><pattern id="grid6" width="20" height="20" patternUnits="userSpaceOnUse"><path d="M 20 0 L 0 0 0 20" fill="none" stroke="#1e2d3d" stroke-width="0.5"/></pattern></defs>
          <rect width="680" height="160" fill="url(#grid6)"/>
          <rect x="270" y="10" width="140" height="36" rx="20" fill="#161e2a" stroke="#00d4ff" stroke-width="1.5"/>
          <text x="340" y="26" fill="#00d4ff" font-size="9" text-anchor="middle">Simulator Result</text>
          <text x="340" y="38" fill="#c8d8e8" font-size="9" text-anchor="middle">vs. reference value</text>
          <line x1="340" y1="46" x2="340" y2="66" stroke="#6a8099" stroke-width="1"/>
          <polygon points="340,66 380,90 340,114 300,90" fill="#161e2a" stroke="#ffb347" stroke-width="1.5"/>
          <text x="340" y="87" fill="#ffb347" font-size="8" text-anchor="middle">within</text>
          <text x="340" y="98" fill="#ffb347" font-size="8" text-anchor="middle">spec ?</text>
          <line x1="380" y1="90" x2="470" y2="90" stroke="#00ff88" stroke-width="1.5"/>
          <rect x="470" y="72" width="90" height="36" rx="3" fill="rgba(0,255,136,0.1)" stroke="#00ff88" stroke-width="1.5"/>
          <text x="515" y="88" fill="#00ff88" font-size="9" text-anchor="middle">PASS</text>
          <text x="515" y="100" fill="#6a8099" font-size="8" text-anchor="middle">Return to service</text>
          <text x="425" y="84" fill="#00ff88" font-size="8">YES</text>
          <line x1="340" y1="114" x2="340" y2="134" stroke="#ff4466" stroke-width="1.5"/>
          <line x1="300" y1="90" x2="200" y2="90" stroke="#ff4466" stroke-width="1.5"/>
          <text x="245" y="84" fill="#ff4466" font-size="8">NO</text>
          <rect x="100" y="72" width="100" height="36" rx="3" fill="rgba(255,68,102,0.1)" stroke="#ff4466" stroke-width="1.5"/>
          <text x="150" y="86" fill="#ff4466" font-size="9" text-anchor="middle">FAIL</text>
          <text x="150" y="99" fill="#6a8099" font-size="8" text-anchor="middle">Investigate &amp; repair</text>
          <rect x="270" y="134" width="140" height="24" rx="3" fill="#161e2a" stroke="#6a8099" stroke-width="1"/>
          <text x="340" y="150" fill="#6a8099" font-size="8" text-anchor="middle">Log in asset management (Equatrace/Insite)</text>
        </svg>
      </div>
    </div>

  </div>

  <!-- RIGHT INFO PANEL -->
  <div class="infopanel scrollbar-thin">
    <div>
      <div class="info-section-title">Quick Specs</div>
      <div class="info-row"><span class="info-key">ECG leads</span><span class="info-val">3 / 5 / 10-lead</span></div>
      <div class="info-row"><span class="info-key">HR accuracy</span><span class="info-val">±10% or 5 bpm</span></div>
      <div class="info-row"><span class="info-key">SpO₂ accuracy</span><span class="info-val">±2–3% Arms</span></div>
      <div class="info-row"><span class="info-key">NIBP accuracy</span><span class="info-val">≤5 mmHg mean</span></div>
      <div class="info-row"><span class="info-key">IBP accuracy</span><span class="info-val">±2 mmHg or ±2%</span></div>
      <div class="info-row"><span class="info-key">Temp accuracy</span><span class="info-val">±0.1°C</span></div>
      <div class="info-row"><span class="info-key">Leakage</span><span class="info-val">&lt;10 µA (CF)</span></div>
      <div class="info-row"><span class="info-key">Applied part class</span><span class="info-val">CF (ECG/IBP)</span></div>
    </div>

    <div>
      <div class="info-section-title">Key Standards</div>
      <div class="info-row"><span class="info-key">Safety</span><span class="info-val">IEC 60601-1</span></div>
      <div class="info-row"><span class="info-key">ECG monitors</span><span class="info-val">IEC 60601-2-27</span></div>
      <div class="info-row"><span class="info-key">NIBP</span><span class="info-val">IEC 80601-2-30</span></div>
      <div class="info-row"><span class="info-key">SpO₂</span><span class="info-val">IEC 80601-2-61</span></div>
      <div class="info-row"><span class="info-key">Temperature</span><span class="info-val">IEC 80601-2-56</span></div>
      <div class="info-row"><span class="info-key">Alarms</span><span class="info-val">IEC 60601-1-8</span></div>
      <div class="info-row"><span class="info-key">Software</span><span class="info-val">IEC 62304 Class C</span></div>
      <div class="info-row"><span class="info-key">Risk mgmt</span><span class="info-val">ISO 14971</span></div>
    </div>

    <div>
      <div class="info-section-title">Clinical Risk Notes</div>
      <div style="font-size:11px;color:var(--text2);line-height:1.7">
        <div style="margin-bottom:6px">⚠ <span style="color:var(--red)">Alarm fatigue:</span> Excessive nuisance alarms lead to desensitisation — a recognised patient safety hazard. Review threshold settings during PPM.</div>
        <div style="margin-bottom:6px">⚠ <span style="color:var(--warn)">IBP zero drift:</span> Undetected drift biases clinical decisions (vasopressor titration, ICP management). Verify at every line change and PPM.</div>
        <div style="margin-bottom:6px">⚠ <span style="color:var(--accent)">Cuff sizing:</span> Wrong NIBP cuff size is the most common source of clinically significant BP error — a training issue as much as an engineering one.</div>
        <div>⚠ <span style="color:var(--accent2)">Cross-infection:</span> Reusable SpO₂ probes and BP cuffs are a recognised fomite risk — verify Trust decontamination policy compliance.</div>
      </div>
    </div>

    <div>
      <div class="info-section-title">Asset Management</div>
      <div class="info-row"><span class="info-key">CMMS</span><span class="info-val">Equatrace / Insite</span></div>
      <div class="info-row"><span class="info-key">Label</span><span class="info-val">Asset + PPM date</span></div>
      <div class="info-row"><span class="info-key">Retirement</span><span class="info-val">Per OEM hours/cycles</span></div>
      <div class="info-row"><span class="info-key">Incidents</span><span class="info-val">MHRA StEIS / Datix</span></div>
      <div class="info-row"><span class="info-key">UDI</span><span class="info-val">Record per EUDAMED</span></div>
    </div>
  </div>

</div>

<script>
function showSection(id, el) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('visible'));
  document.getElementById('sec-' + id).classList.add('visible');
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  el.classList.add('active');
}
</script>
</body>
</html>
