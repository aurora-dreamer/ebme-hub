<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Patient Monitor — Clinical Engineering Reference</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;600&family=IBM+Plex+Sans:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0e14;
    --panel: #111720;
    --panel2: #161e2a;
    --border: #1e2d3d;
    --accent: #00d4ff;
    --accent2: #00ff88;
    --accent3: #ff6b35;
    --warn: #ffb347;
    --text: #c8d8e8;
    --text2: #6a8099;
    --red: #ff4466;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 13px;
    min-height: 100vh;
    overflow-x: hidden;
  }
  .header {
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--panel);
  }
  .header-badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    background: var(--accent);
    color: #000;
    padding: 2px 8px;
    letter-spacing: 2px;
    font-weight: 600;
  }
  .header h1 {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }
  .header span { color: var(--text2); font-size: 12px; margin-left: auto; font-family: 'IBM Plex Mono', monospace; }

  .layout {
    display: grid;
    grid-template-columns: 260px 1fr 280px;
    height: calc(100vh - 51px);
  }

  /* LEFT NAV */
  .sidenav {
    background: var(--panel);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    padding: 12px 0;
  }
  .nav-section {
    padding: 6px 16px 2px;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--text2);
    text-transform: uppercase;
    font-family: 'IBM Plex Mono', monospace;
  }
  .nav-item {
    padding: 9px 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: background 0.15s;
    border-left: 3px solid transparent;
  }
  .nav-item:hover { background: var(--panel2); }
  .nav-item.active {
    background: rgba(0,212,255,0.08);
    border-left-color: var(--accent);
    color: var(--accent);
  }
  .nav-dot {
    width: 8px; height: 8px; border-radius: 50%;
    flex-shrink: 0;
  }

  /* MAIN CANVAS */
  .main {
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .canvas-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .canvas-subtitle {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 16px;
  }

  /* SVG DIAGRAM */
  .diagram-wrap {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px;
    position: relative;
  }
  svg text { font-family: 'IBM Plex Mono', monospace; }

  @keyframes flowDots {
    0% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -60; }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  @keyframes tracedraw {
    0% { stroke-dashoffset: 900; }
    100% { stroke-dashoffset: 0; }
  }
  @keyframes cuffPulse {
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(1.4); }
  }
  .flow-anim { animation: flowDots 1.2s linear infinite; }
  .pulse-anim { animation: pulse 2s ease-in-out infinite; }
  .trace-anim { animation: tracedraw 3.2s linear infinite; }
  .cuff-anim { animation: cuffPulse 1s ease-in-out infinite; transform-origin: bottom; }

  /* INFO CARDS */
  .card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px;
  }
  .card-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--text2);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .card-value {
    font-size: 22px;
    font-weight: 600;
    font-family: 'IBM Plex Mono', monospace;
    color: var(--accent);
  }
  .card-unit { font-size: 12px; color: var(--text2); margin-left: 4px; }
  .card-desc { font-size: 11px; color: var(--text2); margin-top: 4px; }

  /* ALARM TABLE */
  .alarm-table { width: 100%; border-collapse: collapse; }
  .alarm-table th {
    text-align: left;
    padding: 6px 10px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--text2);
    border-bottom: 1px solid var(--border);
    text-transform: uppercase;
  }
  .alarm-table td {
    padding: 7px 10px;
    border-bottom: 1px solid rgba(30,45,61,0.5);
    font-size: 11px;
  }
  .alarm-table tr:hover td { background: var(--panel2); }
  .tag {
    display: inline-block;
    padding: 1px 6px;
    border-radius: 2px;
    font-size: 9px;
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 600;
    letter-spacing: 1px;
  }
  .tag-high { background: rgba(255,68,102,0.2); color: var(--red); border: 1px solid var(--red); }
  .tag-med { background: rgba(255,179,71,0.15); color: var(--warn); border: 1px solid var(--warn); }
  .tag-low { background: rgba(0,212,255,0.1); color: var(--accent); border: 1px solid var(--accent); }
  .tag-ok { background: rgba(0,255,136,0.1); color: var(--accent2); border: 1px solid var(--accent2); }

  /* RIGHT PANEL */
  .infopanel {
    background: var(--panel);
    border-left: 1px solid var(--border);
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .info-section-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--accent);
    text-transform: uppercase;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 8px;
  }
  .info-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 5px 0;
    border-bottom: 1px solid rgba(30,45,61,0.5);
    gap: 8px;
  }
  .info-key { color: var(--text2); font-size: 11px; flex-shrink: 0; }
  .info-val { color: var(--text); font-size: 11px; text-align: right; font-family: 'IBM Plex Mono', monospace; }

  .fault-block {
    background: rgba(255,68,102,0.05);
    border: 1px solid rgba(255,68,102,0.3);
    border-radius: 3px;
    padding: 10px;
  }
  .fault-title {
    color: var(--red);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }
  .fault-item {
    font-size: 11px;
    color: var(--text2);
    padding: 3px 0;
    display: flex;
    gap: 6px;
    align-items: flex-start;
  }
  .fault-item::before { content: '→'; color: var(--red); flex-shrink: 0; }

  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* COMPONENT LIST */
  .component-list { display: flex; flex-direction: column; gap: 8px; }
  .component-item {
    background: var(--panel2);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 10px 12px;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .component-item:hover { border-color: var(--accent); }
  .comp-name {
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 3px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .comp-desc { font-size: 11px; color: var(--text2); line-height: 1.5; }

  /* PPM SCHEDULE */
  .ppm-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 8px;
    padding: 7px 0;
    border-bottom: 1px solid rgba(30,45,61,0.5);
    align-items: center;
  }
  .ppm-task { font-size: 11px; }
  .ppm-freq { font-size: 10px; color: var(--text2); font-family: 'IBM Plex Mono', monospace; }

  .scrollbar-thin::-webkit-scrollbar { width: 4px; }
  .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
  .scrollbar-thin::-webkit-scrollbar-thumb { background: var(--border); }

  /* HIDDEN SECTIONS */
  .section { display: none; }
  .section.visible { display: block; }
</style>
</head>
<body>

<div class="header">
  <div class="header-badge">EBME</div>
  <h1>Patient Monitor — Clinical Engineering Reference</h1>
  <span>IEC 60601-2-27 / -2-30 / -2-34 &nbsp;|&nbsp; Multi-Parameter Bedside Monitor</span>
</div>

<div class="layout">

  <!-- SIDENAV -->
  <div class="sidenav scrollbar-thin">
    <div class="nav-section">Physiological Parameters</div>
    <div class="nav-item active" data-section="ecg" onclick="showSection('ecg', this)">
      <div class="nav-dot" style="background:var(--accent)"></div> ECG Acquisition
    </div>
    <div class="nav-item" data-section="spo2" onclick="showSection('spo2', this)">
      <div class="nav-dot" style="background:var(--accent2)"></div> SpO₂ / Pulse Ox
    </div>
    <div class="nav-item" data-section="nibp" onclick="showSection('nibp', this)">
      <div class="nav-dot" style="background:var(--warn)"></div> NIBP (Oscillometric)
    </div>
    <div class="nav-item" data-section="ibp-temp" onclick="showSection('ibp-temp', this)">
      <div class="nav-dot" style="background:#aa88ff"></div> IBP &amp; Temperature
    </div>
    <div class="nav-section" style="margin-top:8px">System Architecture</div>
    <div class="nav-item" data-section="electronics" onclick="showSection('electronics', this)">
      <div class="nav-dot" style="background:var(--accent)"></div> Electronics &amp; Control
    </div>
    <div class="nav-item" data-section="sensors" onclick="showSection('sensors', this)">
      <div class="nav-dot" style="background:#aa88ff"></div> Sensor / Module Array
    </div>
    <div class="nav-section" style="margin-top:8px">Safety Systems</div>
    <div class="nav-item" data-section="alarms" onclick="showSection('alarms', this)">
      <div class="nav-dot" style="background:var(--red)"></div> Alarm Logic
    </div>
    <div class="nav-item" data-section="artifact" onclick="showSection('artifact', this)">
      <div class="nav-dot" style="background:var(--accent3)"></div> Artifact &amp; Signal Quality
    </div>
    <div class="nav-section" style="margin-top:8px">Servicing</div>
    <div class="nav-item" data-section="ppm" onclick="showSection('ppm', this)">
      <div class="nav-dot" style="background:var(--accent2)"></div> PPM Schedule
    </div>
    <div class="nav-item" data-section="faults" onclick="showSection('faults', this)">
      <div class="nav-dot" style="background:var(--red)"></div> Fault Diagnosis
    </div>
    <div class="nav-item" data-section="accuracy" onclick="showSection('accuracy', this)">
      <div class="nav-dot" style="background:var(--accent)"></div> Accuracy &amp; Testing
    </div>
  </div>

  <!-- MAIN -->
  <div class="main scrollbar-thin">

    <!-- ECG -->
    <div id="sec-ecg" class="section visible">
      <div class="canvas-title">ECG Acquisition</div>
      <div class="canvas-subtitle">Lead System &amp; Signal Conditioning Chain</div>

      <div class="diagram-wrap">
        <svg viewBox="0 0 700 300" width="100%" style="max-height:300px">
          <defs>
            <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#1e2d3d" stroke-width="0.5"/>
            </pattern>
          </defs>
          <rect width="700" height="300" fill="url(#grid)"/>

          <!-- Torso outline with electrodes -->
          <ellipse cx="110" cy="150" rx="55" ry="90" fill="none" stroke="#6a8099" stroke-width="1.5"/>
          <circle cx="90" cy="80" r="6" fill="#00d4ff"/>
          <text x="90" y="65" fill="#00d4ff" font-size="8" text-anchor="middle">RA</text>
          <circle cx="130" cy="80" r="6" fill="#00ff88"/>
          <text x="130" y="65" fill="#00ff88" font-size="8" text-anchor="middle">LA</text>
          <circle cx="90" cy="220" r="6" fill="#ff6b35"/>
          <text x="90" y="238" fill="#ff6b35" font-size="8" text-anchor="middle">RL</text>
          <circle cx="130" cy="220" r="6" fill="#ffb347"/>
          <text x="130" y="238" fill="#ffb347" font-size="8" text-anchor="middle">LL</text>
          <circle cx="110" cy="150" r="6" fill="#aa88ff"/>
          <text x="110" y="145" fill="#aa88ff" font-size="8" text-anchor="middle">V</text>

          <!-- lead wires -->
          <path d="M90,80 Q160,60 220,110" fill="none" stroke="#00d4ff" stroke-width="1" stroke-dasharray="3,2"/>
          <path d="M130,80 Q170,80 220,120" fill="none" stroke="#00ff88" stroke-width="1" stroke-dasharray="3,2"/>
          <path d="M90,220 Q170,200 220,140" fill="none" stroke="#ff6b35" stroke-width="1" stroke-dasharray="3,2"/>
          <path d="M130,220 Q180,190 220,150" fill="none" stroke="#ffb347" stroke-width="1" stroke-dasharray="3,2"/>
          <path d="M110,150 Q170,140 220,130" fill="none" stroke="#aa88ff" stroke-width="1" stroke-dasharray="3,2"/>

          <!-- Patient cable / lead select -->
          <rect x="220" y="95" width="70" height="70" rx="4" fill="#111720" stroke="#6a8099" stroke-width="1.5"/>
          <text x="255" y="120" fill="#c8d8e8" font-size="8" text-anchor="middle">LEAD</text>
          <text x="255" y="132" fill="#c8d8e8" font-size="8" text-anchor="middle">SELECT</text>
          <text x="255" y="147" fill="#6a8099" font-size="8" text-anchor="middle">RLD drive</text>

          <!-- Instrumentation amp -->
          <rect x="320" y="90" width="90" height="80" rx="4" fill="#111720" stroke="#00d4ff" stroke-width="1.5"/>
          <text x="365" y="115" fill="#00d4ff" font-size="9" text-anchor="middle">INSTRUMENTATION</text>
          <text x="365" y="128" fill="#00d4ff" font-size="9" text-anchor="middle">AMPLIFIER</text>
          <text x="365" y="145" fill="#6a8099" font-size="8" text-anchor="middle">CMRR &gt;100 dB</text>
          <text x="365" y="157" fill="#6a8099" font-size="8" text-anchor="middle">gain ~1000×</text>

          <!-- Filters -->
          <rect x="440" y="90" width="90" height="80" rx="4" fill="#111720" stroke="#ffb347" stroke-width="1.5"/>
          <text x="485" y="112" fill="#ffb347" font-size="9" text-anchor="middle">FILTER BANK</text>
          <text x="485" y="128" fill="#6a8099" font-size="8" text-anchor="middle">HPF 0.05/0.5 Hz</text>
          <text x="485" y="140" fill="#6a8099" font-size="8" text-anchor="middle">LPF 40/150 Hz</text>
          <text x="485" y="152" fill="#6a8099" font-size="8" text-anchor="middle">notch 50/60 Hz</text>

          <!-- ADC/DSP -->
          <rect x="560" y="90" width="110" height="80" rx="4" fill="#111720" stroke="#00ff88" stroke-width="1.5"/>
          <text x="615" y="112" fill="#00ff88" font-size="9" text-anchor="middle">ADC + DSP</text>
          <text x="615" y="128" fill="#6a8099" font-size="8" text-anchor="middle">QRS detection</text>
          <text x="615" y="140" fill="#6a8099" font-size="8" text-anchor="middle">HR averaging</text>
          <text x="615" y="152" fill="#6a8099" font-size="8" text-anchor="middle">arrhythmia analysis</text>

          <!-- connecting lines -->
          <line x1="290" y1="130" x2="320" y2="130" stroke="#c8d8e8" stroke-width="1.5" marker-end="none"/>
          <line x1="410" y1="130" x2="440" y2="130" stroke="#c8d8e8" stroke-width="1.5"/>
          <line x1="530" y1="130" x2="560" y2="130" stroke="#c8d8e8" stroke-width="1.5"/>

          <!-- ECG trace output -->
          <rect x="60" y="210" width="610" height="70" rx="3" fill="#0d1319" stroke="#1e2d3d" stroke-width="1"/>
          <text x="70" y="225" fill="#6a8099" font-size="8">Lead II output</text>
          <path d="M70,255 L120,255 L128,255 L133,235 L138,270 L143,245 L148,255 L200,255
                   L220,255 L228,255 L233,235 L238,270 L243,245 L248,255 L300,255
                   L320,255 L328,255 L333,235 L338,270 L343,245 L348,255 L400,255
                   L420,255 L428,255 L433,235 L438,270 L443,245 L448,255 L500,255
                   L520,255 L528,255 L533,235 L538,270 L543,245 L548,255 L600,255
                   L620,255 L628,255 L633,235 L638,270 L643,245 L648,255 L660,255"
                fill="none" stroke="#00ff88" stroke-width="1.5" stroke-dasharray="900" class="trace-anim"/>
        </svg>
      </div>

      <div class="card-grid">
        <div class="card">
          <div class="card-label">Lead Configuration</div>
          <div style="font-size:16px;font-weight:600;color:var(--accent)">3, 5, or 10-lead</div>
          <div class="card-desc">3-lead gives single monitoring lead; 5-lead adds precordial (V); 10-lead derives full 12-lead diagnostic ECG</div>
        </div>
        <div class="card">
          <div class="card-label">Input Impedance</div>
          <div class="card-value">&gt;2.5<span class="card-unit">MΩ</span></div>
          <div class="card-desc">High impedance prevents signal loading from skin-electrode interface</div>
        </div>
        <div class="card">
          <div class="card-label">Defibrillator Protection</div>
          <div style="font-size:16px;font-weight:600;color:var(--warn)">≤5 s Recovery</div>
          <div class="card-desc">Front-end must survive 5 kV defib discharge and recover trace within 5 seconds per IEC 60601-2-27</div>
        </div>
        <div class="card">
          <div class="card-label">HR Averaging</div>
          <div class="card-value">±10%<span class="card-unit">or 5 bpm</span></div>
          <div class="card-desc">Whichever is greater, over the clinically relevant range per IEC 60601-2-27</div>
        </div>
      </div>
    </div>

    <!-- SPO2 -->
    <div id="sec-spo2" class="section">
      <div class="canvas-title">SpO₂ / Pulse Oximetry</div>
      <div class="canvas-subtitle">Photoplethysmographic Measurement Pathway</div>

      <div class="diagram-wrap">
        <svg viewBox="0 0 700 260" width="100%" style="max-height:260px">
          <defs>
            <pattern id="grid2" width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#1e2d3d" stroke-width="0.5"/>
            </pattern>
          </defs>
          <rect width="700" height="260" fill="url(#grid2)"/>

          <!-- finger probe cross-section -->
          <ellipse cx="120" cy="130" rx="70" ry="45" fill="rgba(255,68,102,0.06)" stroke="#6a8099" stroke-width="1.5"/>
          <text x="120" y="60" fill="#6a8099" font-size="9" text-anchor="middle">DIGIT (capillary bed)</text>

          <!-- LEDs -->
          <circle cx="70" cy="100" r="8" fill="#ff4466" class="pulse-anim"/>
          <text x="70" y="85" fill="#ff4466" font-size="8" text-anchor="middle">RED</text>
          <text x="70" y="128" fill="#6a8099" font-size="7" text-anchor="middle">660 nm</text>
          <circle cx="70" cy="160" r="8" fill="#aa2266" class="pulse-anim"/>
          <text x="70" y="180" fill="#aa2266" font-size="8" text-anchor="middle">IR</text>
          <text x="70" y="192" fill="#6a8099" font-size="7" text-anchor="middle">940 nm</text>

          <!-- light path -->
          <path d="M78,100 L165,128" stroke="#ff4466" stroke-width="1" stroke-dasharray="2,2" opacity="0.6"/>
          <path d="M78,160 L165,132" stroke="#aa2266" stroke-width="1" stroke-dasharray="2,2" opacity="0.6"/>

          <!-- photodiode -->
          <rect x="165" y="112" width="24" height="32" rx="3" fill="#111720" stroke="#00d4ff" stroke-width="1.5"/>
          <text x="177" y="155" fill="#00d4ff" font-size="8" text-anchor="middle">PD</text>

          <!-- transimpedance amp -->
          <rect x="230" y="95" width="110" height="70" rx="4" fill="#111720" stroke="#00d4ff" stroke-width="1.5"/>
          <text x="285" y="120" fill="#00d4ff" font-size="9" text-anchor="middle">TRANSIMPEDANCE</text>
          <text x="285" y="133" fill="#00d4ff" font-size="9" text-anchor="middle">AMPLIFIER</text>
          <text x="285" y="150" fill="#6a8099" font-size="8" text-anchor="middle">time-multiplexed R/IR</text>

          <line x1="189" y1="128" x2="230" y2="128" stroke="#c8d8e8" stroke-width="1.5"/>

          <!-- AC/DC separation -->
          <rect x="380" y="95" width="110" height="70" rx="4" fill="#111720" stroke="#ffb347" stroke-width="1.5"/>
          <text x="435" y="118" fill="#ffb347" font-size="9" text-anchor="middle">AC/DC</text>
          <text x="435" y="131" fill="#ffb347" font-size="9" text-anchor="middle">SEPARATION</text>
          <text x="435" y="148" fill="#6a8099" font-size="8" text-anchor="middle">pulsatile vs baseline</text>
          <line x1="340" y1="128" x2="380" y2="128" stroke="#c8d8e8" stroke-width="1.5"/>

          <!-- Ratio of ratios -->
          <rect x="530" y="90" width="140" height="80" rx="4" fill="#111720" stroke="#00ff88" stroke-width="1.5"/>
          <text x="600" y="112" fill="#00ff88" font-size="9" text-anchor="middle">RATIO-OF-RATIOS</text>
          <text x="600" y="130" fill="#c8d8e8" font-size="11" text-anchor="middle" font-weight="600">R = (AC/DC)ᵣₑ𝒹 ÷ (AC/DC)ᵢᵣ</text>
          <text x="600" y="148" fill="#6a8099" font-size="8" text-anchor="middle">mapped to SpO₂ via</text>
